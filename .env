# =============================================
# BASE SWAP BOT - KONFIGURASI ENVIRONMENT
# =============================================

# ── WALLET ──────────────────────────────────
# Private key wallet kamu (tanpa 0x di depan)
PRIVATE_KEY=your_private_key_here

# ── NETWORK ─────────────────────────────────
# RPC URL untuk Base Mainnet (gratis dari Alchemy/Infura/public)
RPC_URL=https://mainnet.base.org

# ── SWAP SETTINGS ───────────────────────────
# Token yang ingin kamu jual (address kontrak)
TOKEN_IN=0x4200000000000000000000000000000000000006

# Token yang ingin kamu beli (address kontrak)
TOKEN_OUT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Jumlah token yang akan di-swap (dalam unit terkecil / wei)
# Contoh: 0.001 ETH = 1000000000000000
AMOUNT_IN=1000000000000000

# Slippage toleransi dalam persen (0.5 = 0.5%)
SLIPPAGE_PERCENT=0.5

# Fee tier pool Uniswap V3: 500=0.05%, 3000=0.3%, 10000=1%
POOL_FEE=3000

# Deadline transaksi dalam menit
DEADLINE_MINUTES=20
