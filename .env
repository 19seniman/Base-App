# --- Kredibilitas & Koneksi ---
PRIVATE_KEY=isi_private_key_wallet_kamu
RPC_URL=https://1rpc.io/base

# --- Pengaturan Token Masuk ---
# Alamat Kontrak USDC di Base (0x8335...)
TOKEN_IN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Jumlah USDC yang ingin di-swap PER TRANSAKSI
# Jika ingin 0.1 USDC, tulis 100000 (USDC pakai 6 desimal)
AMOUNT_IN=100000

# --- Pengaturan Transaksi ---
# Pool Fee: 500 = 0.05% (Terbaik untuk USDC/ETH dan USDC/USDT)
POOL_FEE=500
SLIPPAGE_PERCENT=0.5
DEADLINE_MINUTES=20

# --- Fitur Otomatisasi ---
# Jeda antar transaksi (15000 = 15 detik) agar tidak kena limit RPC
DELAY_BETWEEN_SWAP=15000
# Jika "true", bot langsung jalan tanpa tanya y/n lagi
AUTO_CONFIRM=false
